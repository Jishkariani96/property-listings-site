---
import { getProperties } from "../lib/properties";

const properties = getProperties();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Property Listings</title>
  </head>
  <body>
    <h1>Properties</h1>

    <ul>
      {properties.map((p) => (
        <li>
          <h2>{p.title}</h2>
          <p>{p.location}</p>
          <p>${p.price}</p>
          <p>{p.bedrooms} bed • {p.bathrooms} bath • {p.area} sqm</p>
        </li>
      ))}
    </ul>
  </body>
</html>